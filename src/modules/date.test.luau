local date = require("@eryx/date")
local test = require("@eryx/test")

local suite = test.Suite.new("date")

-- ── Utility ──────────────────────────────────────────────────────────────────

suite:Test("isLeap: 2000 (div 400)", function()
	test.expect(date.isLeap(2000)):ToBeTrue()
end)
suite:Test("isLeap: 1900 (div 100, not 400)", function()
	test.expect(date.isLeap(1900)):ToBeFalse()
end)
suite:Test("isLeap: 2024 (div 4)", function()
	test.expect(date.isLeap(2024)):ToBeTrue()
end)
suite:Test("isLeap: 2023 (non-leap)", function()
	test.expect(date.isLeap(2023)):ToBeFalse()
end)

suite:Test("daysInMonth: Feb 2024 (leap) = 29", function()
	test.expect(date.daysInMonth(2024, 2)):ToBe(29)
end)
suite:Test("daysInMonth: Feb 2023 (non-leap) = 28", function()
	test.expect(date.daysInMonth(2023, 2)):ToBe(28)
end)
suite:Test("daysInMonth: Jan = 31", function()
	test.expect(date.daysInMonth(2024, 1)):ToBe(31)
end)
suite:Test("daysInMonth: Apr = 30", function()
	test.expect(date.daysInMonth(2024, 4)):ToBe(30)
end)

suite:Test("timezone: returns a non-empty string", function()
	local tz = date.timezone()
	test.expect(tz):ToBeType("string")
	test.expect(#tz):ToBeGreaterThan(0)
end)
suite:Test("timezones: returns a non-empty table", function()
	local zones = date.timezones()
	test.expect(zones):ToBeType("table")
	test.expect(#zones):ToBeGreaterThan(0)
end)
suite:Test("timezones: contains the system timezone", function()
	test.expect(date.timezones()):ToContain(date.timezone())
end)

-- ── Duration constructors ────────────────────────────────────────────────────

suite:Test("seconds: totalSeconds", function()
	test.expect(date.seconds(90).totalSeconds):ToBe(90)
end)
suite:Test("seconds: component fields (1m 30s)", function()
	local d = date.seconds(90)
	test.expect(d.minutes):ToBe(1)
	test.expect(d.seconds):ToBe(30)
end)
suite:Test("milliseconds: totalMilliseconds", function()
	test.expect(date.milliseconds(1500).totalMilliseconds):ToBe(1500)
end)
suite:Test("milliseconds: component fields (1s 500ms)", function()
	local d = date.milliseconds(1500)
	test.expect(d.seconds):ToBe(1)
	test.expect(d.milliseconds):ToBe(500)
end)
suite:Test("minutes: totalMinutes", function()
	test.expect(date.minutes(90).totalMinutes):ToBe(90)
end)
suite:Test("minutes: component fields (1h 30m)", function()
	local d = date.minutes(90)
	test.expect(d.hours):ToBe(1)
	test.expect(d.minutes):ToBe(30)
end)
suite:Test("hours: totalHours", function()
	test.expect(date.hours(3).totalHours):ToBe(3)
end)
suite:Test("hours: 2h = 120 totalMinutes", function()
	test.expect(date.hours(2).totalMinutes):ToBe(120)
end)
suite:Test("days: totalDays", function()
	test.expect(date.days(7).totalDays):ToBe(7)
end)
suite:Test("days: 1 day = 24 totalHours", function()
	test.expect(date.days(1).totalHours):ToBe(24)
end)
suite:Test("nanoseconds: totalNanoseconds", function()
	test.expect(date.nanoseconds(1000).totalNanoseconds):ToBe(1000)
end)
suite:Test("nanoseconds: 1e9 ns = 1 whole second", function()
	local d = date.nanoseconds(1_000_000_000)
	test.expect(d.seconds):ToBe(1)
	test.expect(d.nanoseconds):ToBe(0)
end)

-- ── Duration arithmetic ──────────────────────────────────────────────────────

suite:Test("duration +", function()
	test.expect((date.seconds(30) + date.seconds(30)).totalSeconds):ToBe(60)
end)
suite:Test("duration -", function()
	test.expect((date.hours(2) - date.hours(1)).totalHours):ToBe(1)
end)
suite:Test("duration * scalar", function()
	test.expect((date.seconds(10) * 3).totalSeconds):ToBe(30)
end)
suite:Test("duration / scalar", function()
	test.expect((date.seconds(30) / 3).totalSeconds):ToBe(10)
end)
suite:Test("duration unary -", function()
	test.expect((-date.seconds(5)).totalSeconds):ToBe(-5)
end)
suite:Test("duration Abs of negative", function()
	test.expect((-date.seconds(5)):Abs().totalSeconds):ToBe(5)
end)
suite:Test("duration Abs of positive unchanged", function()
	test.expect(date.seconds(5):Abs().totalSeconds):ToBe(5)
end)
suite:Test("duration == (60s == 1min)", function()
	test.expect(date.seconds(60) == date.minutes(1)):ToBeTrue()
end)
suite:Test("duration <", function()
	test.expect(date.seconds(1) < date.seconds(2)):ToBeTrue()
end)
suite:Test("duration <= (equal case)", function()
	test.expect(date.seconds(1) <= date.seconds(1)):ToBeTrue()
end)
suite:Test("duration tostring returns a string", function()
	test.expect(tostring(date.seconds(1))):ToBeType("string")
end)

-- ── fromTimestamp ────────────────────────────────────────────────────────────

-- All tests pin to UTC to avoid machine-local-timezone dependence.
-- Unix epoch: 1970-01-01T00:00:00Z (Thursday, ISO weekday 4)

suite:Test("fromTimestamp: epoch calendar fields", function()
	local dt = date.fromTimestamp(0, "UTC")
	test.expect(dt.year):ToBe(1970)
	test.expect(dt.month):ToBe(1)
	test.expect(dt.day):ToBe(1)
	test.expect(dt.hour):ToBe(0)
	test.expect(dt.minute):ToBe(0)
	test.expect(dt.second):ToBe(0)
	test.expect(dt.nanosecond):ToBe(0)
end)
suite:Test("fromTimestamp: epoch zone and offset", function()
	local dt = date.fromTimestamp(0, "UTC")
	test.expect(dt.zone):ToBe("UTC")
	test.expect(dt.offset):ToBe(0)
end)
suite:Test("fromTimestamp: epoch weekday = Thursday (4)", function()
	test.expect(date.fromTimestamp(0, "UTC").weekday):ToBe(4)
end)
suite:Test("fromTimestamp: epoch dayOfYear = 1", function()
	test.expect(date.fromTimestamp(0, "UTC").dayOfYear):ToBe(1)
end)
suite:Test("fromTimestamp: epoch isLeap = false", function()
	test.expect(date.fromTimestamp(0, "UTC").isLeap):ToBeFalse()
end)
suite:Test("fromTimestamp: epoch isDst = false", function()
	test.expect(date.fromTimestamp(0, "UTC").isDst):ToBeFalse()
end)
suite:Test("fromTimestamp: +1 day = Jan 2", function()
	local dt = date.fromTimestamp(86400, "UTC")
	test.expect(dt.day):ToBe(2)
	test.expect(dt.month):ToBe(1)
end)
suite:Test("fromTimestamp: 2000-02-29 leap day (951825600)", function()
	local dt = date.fromTimestamp(951825600, "UTC")
	test.expect(dt.year):ToBe(2000)
	test.expect(dt.month):ToBe(2)
	test.expect(dt.day):ToBe(29)
	test.expect(dt.hour):ToBe(12)
	test.expect(dt.isLeap):ToBeTrue()
end)
suite:Test("fromTimestamp: fractional seconds -> nanoseconds", function()
	-- 0.5s = 500_000_000 ns
	test.expect(date.fromTimestamp(0.5, "UTC").nanosecond):ToBe(500_000_000)
end)

-- ── fromIso ──────────────────────────────────────────────────────────────────

suite:Test("fromIso: epoch ToUnix = 0", function()
	test.expect(date.fromIso("1970-01-01T00:00:00+00:00"):ToUnix()):ToBe(0)
end)
suite:Test("fromIso: calendar fields", function()
	local dt = date.fromIso("2024-03-15T10:30:45+00:00")
	test.expect(dt.year):ToBe(2024)
	test.expect(dt.month):ToBe(3)
	test.expect(dt.day):ToBe(15)
	test.expect(dt.hour):ToBe(10)
	test.expect(dt.minute):ToBe(30)
	test.expect(dt.second):ToBe(45)
end)
suite:Test("fromIso: fixed offset is preserved as zone string", function()
	local dt = date.fromIso("1970-01-01T01:00:00+01:00")
	test.expect(dt.hour):ToBe(1)
	test.expect(dt.offset):ToBe(3600)
end)
suite:Test("fromIso: invalid string throws", function()
	test.expect(function() date.fromIso("not a date") end):ToError()
end)

-- ── fromFields ───────────────────────────────────────────────────────────────

suite:Test("fromFields: fields round-trip", function()
	local dt = date.fromFields(
		{ year = 2024, month = 3, day = 15, hour = 10, minute = 30, second = 45 },
		"UTC"
	)
	test.expect(dt.year):ToBe(2024)
	test.expect(dt.month):ToBe(3)
	test.expect(dt.day):ToBe(15)
	test.expect(dt.hour):ToBe(10)
	test.expect(dt.minute):ToBe(30)
	test.expect(dt.second):ToBe(45)
end)
suite:Test("fromFields: optional fields default to 0", function()
	local dt = date.fromFields({ year = 2024, month = 1, day = 1 }, "UTC")
	test.expect(dt.hour):ToBe(0)
	test.expect(dt.minute):ToBe(0)
	test.expect(dt.second):ToBe(0)
	test.expect(dt.nanosecond):ToBe(0)
end)
suite:Test("fromFields: matches equivalent fromTimestamp", function()
	local a = date.fromFields({ year = 1970, month = 1, day = 1 }, "UTC")
	test.expect(a:ToUnix()):ToBe(0)
end)
suite:Test("fromFields: out-of-range day overflows into next month", function()
	-- Feb 30 2023 overflows to Mar 2
	local dt = date.fromFields({ year = 2023, month = 2, day = 30 }, "UTC")
	test.expect(dt.month):ToBe(3)
	test.expect(dt.day):ToBe(2)
end)
suite:Test("fromFields: invalid timezone throws", function()
	test.expect(function()
		date.fromFields({ year = 2024, month = 1, day = 1 }, "Not/Real")
	end):ToError()
end)

-- ── parse ────────────────────────────────────────────────────────────────────

suite:Test("parse: %Y-%m-%d %H:%M:%S", function()
	local dt = date.parse("2024-03-15 10:30:45", "%Y-%m-%d %H:%M:%S", "UTC")
	test.expect(dt.year):ToBe(2024)
	test.expect(dt.month):ToBe(3)
	test.expect(dt.day):ToBe(15)
	test.expect(dt.hour):ToBe(10)
	test.expect(dt.minute):ToBe(30)
	test.expect(dt.second):ToBe(45)
end)
suite:Test("parse: %F shorthand (%Y-%m-%d)", function()
	local dt = date.parse("1970-01-01", "%F", "UTC")
	test.expect(dt:ToUnix()):ToBe(0)
end)
suite:Test("parse: mismatched format throws", function()
	test.expect(function()
		date.parse("not-a-date", "%Y-%m-%d", "UTC")
	end):ToError()
end)

-- ── DateTime methods ─────────────────────────────────────────────────────────

suite:Test("Format: %Y-%m-%d", function()
	test.expect(date.fromTimestamp(0, "UTC"):Format("%Y-%m-%d")):ToBe("1970-01-01")
end)
suite:Test("Format: %H:%M (no sub-seconds)", function()
	test.expect(date.fromTimestamp(0, "UTC"):Format("%H:%M")):ToBe("00:00")
end)
suite:Test("Format: %S includes sub-seconds", function()
	-- %S always appends nanoseconds per the docs
	test.expect(date.fromTimestamp(0, "UTC"):Format("%H:%M:%S")):ToBe("00:00:00.000000000")
end)
suite:Test("FormatUtc: date portion matches UTC", function()
	test.expect(date.fromTimestamp(0, "UTC"):FormatUtc("%Y-%m-%d")):ToBe("1970-01-01")
end)
suite:Test("FormatUtc: time with sub-seconds", function()
	test.expect(date.fromTimestamp(0, "UTC"):FormatUtc("%H:%M:%S")):ToBe("00:00:00.000000000")
end)
suite:Test("ToIsoString: epoch begins with 1970-01-01", function()
	test.expect(date.fromTimestamp(0, "UTC"):ToIsoString()):ToMatch("^1970%-01%-01")
end)
suite:Test("ToUnix: epoch = 0", function()
	test.expect(date.fromTimestamp(0, "UTC"):ToUnix()):ToBe(0)
end)
suite:Test("ToUnixMs: epoch = 0", function()
	test.expect(date.fromTimestamp(0, "UTC"):ToUnixMs()):ToBe(0)
end)
suite:Test("ToUnixMs: 1s = 1000ms", function()
	test.expect(date.fromTimestamp(1, "UTC"):ToUnixMs()):ToBe(1000)
end)
suite:Test("StartOfDay: zeroes time fields", function()
	-- 1970-01-02T01:01:01Z
	local dt = date.fromTimestamp(86400 + 3661, "UTC"):StartOfDay()
	test.expect(dt.hour):ToBe(0)
	test.expect(dt.minute):ToBe(0)
	test.expect(dt.second):ToBe(0)
	test.expect(dt.nanosecond):ToBe(0)
end)
suite:Test("StartOfDay: preserves date", function()
	local dt = date.fromTimestamp(86400 + 3661, "UTC"):StartOfDay()
	test.expect(dt.day):ToBe(2)
	test.expect(dt.month):ToBe(1)
	test.expect(dt.year):ToBe(1970)
end)
suite:Test("AddMonths: Jan 31 + 1 clamps to Feb 28 (non-leap)", function()
	local dt = date.fromFields({ year = 2023, month = 1, day = 31 }, "UTC"):AddMonths(1)
	test.expect(dt.month):ToBe(2)
	test.expect(dt.day):ToBe(28)
end)
suite:Test("AddMonths: Jan 31 + 1 clamps to Feb 29 (leap)", function()
	local dt = date.fromFields({ year = 2024, month = 1, day = 31 }, "UTC"):AddMonths(1)
	test.expect(dt.month):ToBe(2)
	test.expect(dt.day):ToBe(29)
end)
suite:Test("AddMonths: -1 wraps year back", function()
	local dt = date.fromFields({ year = 2024, month = 1, day = 15 }, "UTC"):AddMonths(-1)
	test.expect(dt.year):ToBe(2023)
	test.expect(dt.month):ToBe(12)
	test.expect(dt.day):ToBe(15)
end)
suite:Test("AddYears: +1 from Feb 29 clamps to Feb 28", function()
	local dt = date.fromFields({ year = 2024, month = 2, day = 29 }, "UTC"):AddYears(1)
	test.expect(dt.year):ToBe(2025)
	test.expect(dt.month):ToBe(2)
	test.expect(dt.day):ToBe(28)
end)
suite:Test("AddYears: +4 from Feb 29 lands on Feb 29", function()
	local dt = date.fromFields({ year = 2024, month = 2, day = 29 }, "UTC"):AddYears(4)
	test.expect(dt.year):ToBe(2028)
	test.expect(dt.month):ToBe(2)
	test.expect(dt.day):ToBe(29)
end)
suite:Test("Diff: 1-day gap = 86400 totalSeconds", function()
	local d1 = date.fromTimestamp(0, "UTC")
	local d2 = date.fromTimestamp(86400, "UTC")
	test.expect(d2:Diff(d1).totalSeconds):ToBe(86400)
end)
suite:Test("Diff: self - self = 0", function()
	local d = date.fromTimestamp(12345, "UTC")
	test.expect(d:Diff(d).totalSeconds):ToBe(0)
end)
suite:Test("Diff: earlier - later is negative", function()
	local d1 = date.fromTimestamp(0, "UTC")
	local d2 = date.fromTimestamp(3600, "UTC")
	test.expect(d1:Diff(d2).totalSeconds):ToBe(-3600)
end)

-- ── WithZone ─────────────────────────────────────────────────────────────────

suite:Test("WithZone: UTC instant unchanged", function()
	test.expect(date.fromTimestamp(0, "UTC"):WithZone("America/New_York"):ToUnix()):ToBe(0)
end)
suite:Test("WithZone: zone name updated", function()
	test.expect(date.fromTimestamp(0, "UTC"):WithZone("America/New_York").zone):ToBe("America/New_York")
end)
suite:Test("WithZone: invalid zone throws", function()
	test.expect(function()
		date.fromTimestamp(0, "UTC"):WithZone("Not/AZone")
	end):ToError()
end)

-- ── DateTime operators ───────────────────────────────────────────────────────

suite:Test("dt + duration advances instant", function()
	local dt = date.fromTimestamp(0, "UTC") + date.seconds(3600)
	test.expect(dt.hour):ToBe(1)
end)
suite:Test("dt - duration rewinds instant", function()
	local dt = date.fromTimestamp(3600, "UTC") - date.seconds(3600)
	test.expect(dt:ToUnix()):ToBe(0)
end)
suite:Test("dt == dt (same UTC, different zone)", function()
	local utc = date.fromTimestamp(0, "UTC")
	local ny = utc:WithZone("America/New_York")
	test.expect(utc == ny):ToBeTrue()
end)
suite:Test("dt < dt", function()
	local d1 = date.fromTimestamp(0, "UTC")
	local d2 = date.fromTimestamp(1, "UTC")
	test.expect(d1 < d2):ToBeTrue()
end)
suite:Test("dt <= dt (equal case)", function()
	local d = date.fromTimestamp(0, "UTC")
	test.expect(d <= d):ToBeTrue()
end)
suite:Test("dt tostring returns a string", function()
	test.expect(tostring(date.fromTimestamp(0, "UTC"))):ToBeType("string")
end)

-- ── now ──────────────────────────────────────────────────────────────────────

suite:Test("now: UTC zone", function()
	test.expect(date.now("UTC").zone):ToBe("UTC")
end)
suite:Test("now: year is plausible", function()
	test.expect(date.now("UTC").year):ToBeGreaterThanOrEqual(2024)
end)
suite:Test("now: no-arg uses system zone", function()
	test.expect(date.now().zone):ToBe(date.timezone())
end)
suite:Test("now: successive calls are non-decreasing", function()
	local a = date.now("UTC")
	local b = date.now("UTC")
	test.expect(a <= b):ToBeTrue()
end)

return suite
